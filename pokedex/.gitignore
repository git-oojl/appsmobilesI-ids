# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.old

# Ionic / Angular build output
www/
dist/
tmp/
out-tsc/
.angular/
.cache/

# Angular cache
.angular/cache/

# Capacitor generated web assets copied into native projects
android/app/src/main/assets/public/
ios/App/App/public/

# Environment files
.env
.env.*
!.env.example

# Logs
logs/
*.log

# Runtime files
*.pid
*.seed
*.pid.lock

# Coverage / testing
coverage/
.nyc_output/
junit.xml

# TypeScript
*.tsbuildinfo

# Editor folders
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Android / Gradle
android/.gradle/
android/build/
android/app/build/
android/captures/
android/.externalNativeBuild/
android/.cxx/
android/local.properties

# Android generated APK/AAB files
*.apk
*.ap_
*.aab

# Android Studio generated files
android/*.iml
android/app/*.iml

# Gradle local files
.gradle/
build/

# Do NOT ignore Gradle wrapper files.
# These should stay tracked:
# android/gradlew
# android/gradlew.bat
# android/gradle/wrapper/gradle-wrapper.jar
# android/gradle/wrapper/gradle-wrapper.properties

# iOS, in case Capacitor iOS ever gets added
ios/App/build/
ios/App/DerivedData/
ios/App/Pods/
ios/App/Podfile.lock
ios/App/*.xcworkspace/xcuserdata/
ios/App/*.xcodeproj/xcuserdata/
ios/App/*.xcodeproj/project.xcworkspace/xcuserdata/

# Xcode
*.xcuserstate
*.xcscmblueprint

